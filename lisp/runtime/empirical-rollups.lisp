(defun persist-rollups (daily weekly monthly quarterly yearly)
  (write-jsonl (daily-rollups-path) daily)
  (write-jsonl (weekly-rollups-path) weekly)
  (write-jsonl (monthly-rollups-path) monthly)
  (write-jsonl (quarterly-rollups-path) quarterly)
  (write-jsonl (yearly-rollups-path) yearly)
  (labels ((post-rollups (endpoint rows)
             (dolist (row rows)
               (handler-case (api-post endpoint row)
                 (error () (return))))))
    (post-rollups "/api/rollups/daily" daily)
    (post-rollups "/api/rollups/weekly" weekly)
    (post-rollups "/api/rollups/monthly" monthly)
    (post-rollups "/api/rollups/quarterly" quarterly)
    (post-rollups "/api/rollups/yearly" yearly)))

(defun rebuild-rollups ()
  (let* ((reports (load-tick-reports))
         (daily (build-daily-rollups reports))
         (weekly (build-weekly-rollups daily))
         (monthly (build-monthly-rollups daily))
         (quarterly (build-quarterly-rollups monthly))
         (yearly (build-yearly-rollups quarterly)))
    (persist-rollups daily weekly monthly quarterly yearly)
    (json-object :daily daily :weekly weekly :monthly monthly :quarterly quarterly :yearly yearly)))
